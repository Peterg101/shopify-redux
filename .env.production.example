# FITD Platform — Production Environment Variables
# Copy to .env and fill in all values before deploying.

# ── Domain ────────────────────────────────────────────────────────
DOMAIN=fitd.dev
ACME_EMAIL=your-email@example.com

# ── Secrets ───────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Add https://api.fitd.dev/auth/google/callback as authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
# Set callback URL to https://api.fitd.dev/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe (https://dashboard.stripe.com/apikeys) — use LIVE keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend email (https://resend.com/api-keys)
# Requires verified domain for production sending
RESEND_API_KEY=
EMAIL_FROM=FITD <noreply@fitd.dev>

# Anthropic API (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# ShipEngine (https://www.shipengine.com/account/api-keys)
SHIPENGINE_API_KEY=

# Meshy.ai (https://app.meshy.ai) — optional
MESHY_API_KEY=

# ── S3 Storage (replace MinIO with real S3) ───────────────────────
# For AWS S3:
#   S3_ENDPOINT_URL=https://s3.amazonaws.com
#   S3_PUBLIC_URL=https://fitd-files.s3.amazonaws.com
# For Backblaze B2:
#   S3_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
#   S3_PUBLIC_URL=https://s3.us-west-004.backblazeb2.com
S3_ENDPOINT_URL=
S3_PUBLIC_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=fitd-files

# ── Defaults ──────────────────────────────────────────────────────
CAD_PROVIDER=anthropic
MOCK_GENERATION=false
