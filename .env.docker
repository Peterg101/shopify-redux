# FITD Platform — Docker Compose Environment Variables
# Copy this file to .env and fill in your secrets:
#   cp .env.docker .env

# ── Secrets (fill these in) ───────────────────────────────────────

# Shared JWT secret for inter-service auth
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Google OAuth (from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (from https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ShipEngine (from https://www.shipengine.com/account/api-keys)
SHIPENGINE_API_KEY=

# Anthropic API key — only needed if CAD_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Resend email service (from https://resend.com/api-keys)
# Optional — email verification/password reset degrade gracefully without it
RESEND_API_KEY=
EMAIL_FROM=FITD <noreply@fitd.dev>

# ── Defaults (usually don't need to change) ───────────────────────

# CAD generation LLM backend: "ollama" (local, free) or "anthropic" (cloud)
CAD_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5-coder:7b

# Set to "true" to enable mock generation (no real AI calls)
MOCK_GENERATION=false
