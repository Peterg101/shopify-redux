# FITD Platform — Docker Compose Environment Variables
# Copy this file to .env and fill in your secrets:
#   cp .env.docker .env

# ── Secrets (fill these in) ───────────────────────────────────────

# Shared JWT secret for inter-service auth
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=4cda0102af7519086b04250c63ae030be85e0cac79d6544653dd4242138e2870

# Google OAuth (from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=854876909268-92r1ja775v91cciriu3blce5ulentf9f.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# Meshy.ai 3D generation (from https://app.meshy.ai)
MESHY_API_KEY=

# Stripe (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_ENDPOINT_SECRET=
STRIPE_WEBHOOK_SECRET=

# ShipEngine (from https://www.shipengine.com/account/api-keys)
SHIPENGINE_API_KEY=

# Anthropic API key — only needed if CAD_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── Defaults (usually don't need to change) ───────────────────────

# CAD generation LLM backend: "ollama" (local, free) or "anthropic" (cloud)
CAD_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5-coder:7b
