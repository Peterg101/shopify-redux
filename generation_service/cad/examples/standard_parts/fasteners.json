[
  {
    "description": "M3 hex bolt, 5.5mm across flats, 2mm head height, 10mm shaft",
    "keywords": ["bolt", "M3", "hex", "fastener", "screw", "ISO 4032"],
    "parameters": {
      "hex_af": 5.5, "head_h": 2.0, "shaft_d": 3.0, "shaft_l": 10.0
    },
    "steps": [
      {"op": "create_cylinder", "tag": "head", "radius": "$hex_af / 2 + 0.5", "height": "$head_h"},
      {"op": "union", "tag": "shaft", "body": {"type": "cylinder", "radius": "$shaft_d / 2", "height": "$shaft_l"},
       "translate": [0, 0, "-$shaft_l"], "depends_on": ["head"]},
      {"op": "chamfer", "tag": "head_chamfer", "size": 0.3, "edges": ">Z", "depends_on": ["head"]}
    ]
  },
