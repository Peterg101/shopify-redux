# Minimal sandbox image for executing LLM-generated CadQuery code.
# Contains ONLY CadQuery + Python stdlib — no network libs, no secrets,
# no fitd_schemas, no httpx/redis/anthropic/openai.
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libglib2.0-0 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir cadquery

RUN useradd --create-home --shell /bin/false sandbox
USER sandbox
WORKDIR /home/sandbox
